# ============================================================
# Sistema IDS Institucional - Archivo de configuración
# IMPORTANTE: Copia este archivo como ".env" y llena tus datos.
#             NUNCA subas el archivo ".env" real a GitHub.
# ============================================================

# --- Credenciales del servidor SMTP (para enviar alertas) ---
# Para Gmail debes activar: "Contraseñas de aplicación" en tu cuenta
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASSWORD=tu_contrasena_de_aplicacion

# --- Correo del administrador que recibirá las alertas ---
ADMIN_EMAIL=admin@tudominio.com

# --- Nombre de la organización (aparece en los correos) ---
ORG_NAME=Institución Educativa

# --- Interfaz de red a monitorear (ej: eth0, enp3s0, wlan0) ---
# Para ver tus interfaces: ip link show
NETWORK_INTERFACE=eth0

# --- API Key de AbuseIPDB (opcional, para Threat Intelligence) ---
# Regístrate gratis en: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=tu_api_key_aqui

# --- Nivel de log: DEBUG, INFO, WARNING, ERROR ---
LOG_LEVEL=INFO
